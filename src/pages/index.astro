---
import Base from '~/layouts/Base.astro';
import SiteNav from '~/components/SiteNav.astro';
import { allSeries } from '~/content';

// Every artwork image, used as the full-viewport collage backdrop. Pad to a
// multiple of the largest grid (18 cells) so the grid is always fully covered.
const images = allSeries.flatMap((s) =>
  s.works.flatMap((w) => w.images.map((img) => ({ src: `/paintings/${s.id}/${img.file}`, alt: w.title })))
);
const cells = Array.from({ length: 18 }, (_, i) => images[i % images.length]).filter(Boolean);
---

<Base title="CILA — Carolina Amat">
  <main class="relative h-screen w-full overflow-hidden bg-ink-900">
    <!-- Collage backdrop — a tight grid of works covering the viewport -->
    <div class="absolute inset-0 grid grid-cols-3 grid-rows-6 gap-1 md:grid-cols-6 md:grid-rows-3">
      {cells.map((a) => (
        <img src={a!.src} alt={a!.alt} class="h-full w-full object-cover" />
      ))}
    </div>

    <!-- Scrim for legibility -->
    <div class="absolute inset-0 bg-gradient-to-b from-ink-900/60 via-ink-900/30 to-ink-900/70"></div>

    <!-- Nav -->
    <div class="absolute inset-x-0 top-0 z-10">
      <SiteNav variant="light" />
    </div>

    <!-- Hero -->
    <div class="absolute inset-0 z-10 flex flex-col items-center justify-center px-8 text-center">
      <div class="mb-5 font-sans text-[11px] uppercase tracking-widest text-cream-50/70">
        Carolina Amat · Venezuelan Artist
      </div>
      <h1 class="mb-9 font-serif text-5xl font-normal leading-[1.04] tracking-tight text-cream-50 sm:text-6xl md:text-7xl">
        A life in color,<br />memory, and flight.
      </h1>
      <a
        href="/gallery"
        class="rounded-sm bg-cream-50 px-8 py-4 font-sans text-[13px] uppercase tracking-wider text-ink-900 transition-colors hover:bg-cream-100"
      >
        See exhibitions →
      </a>
    </div>
  </main>
</Base>
