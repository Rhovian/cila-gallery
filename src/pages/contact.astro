---
import Base from '~/layouts/Base.astro';
---

<Base title="Contact — CILA">
  <main class="mx-auto max-w-3xl px-10 py-20">
    <a href="/" class="font-sans text-[11px] uppercase tracking-widest text-ink-500 hover:text-ink-700">← Back</a>
    <h1 class="mt-12 font-serif text-5xl font-normal">Contact</h1>
    <div class="mt-8 font-serif text-[17px] leading-relaxed text-ink-700">
      <p>For inquiries about works, commissions, or exhibitions:</p>
      <p class="mt-4">
        <a href="mailto:hello@cilamat.gallery" class="underline underline-offset-4">
          hello@cilamat.gallery
        </a>
      </p>
    </div>
  </main>
</Base>
