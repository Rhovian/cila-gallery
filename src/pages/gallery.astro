---
import Base from '~/layouts/Base.astro';
import SiteNav from '~/components/SiteNav.astro';
import { allSeries } from '~/content';
---

<Base title="Exhibitions — CILA">
  <main class="min-h-screen">
    <SiteNav current="gallery" />

    <section
      data-exhibitions
      data-state="grid"
      class="mx-auto max-w-5xl px-6 py-16 md:px-10 md:py-24"
    >
      <header data-grid-header>
        <h1 class="font-serif text-5xl font-normal leading-[1.05] tracking-tight md:text-6xl">
          Exhibitions
        </h1>
        <p class="mt-5 font-serif text-[18px] italic leading-relaxed text-ink-600">
          A virtual exhibition{allSeries.length === 1 ? '' : 's'}, room by room.
        </p>
      </header>

      <div
        data-grid
        class="mt-12 grid grid-cols-1 gap-x-8 gap-y-12 sm:grid-cols-2 lg:grid-cols-3"
      >
        {allSeries.map((s) => {
          const cover = s.works[0]?.images[0];
          const paragraphs = (s.statement ?? '')
            .split(/\n\s*\n/)
            .map((p) => p.trim())
            .filter(Boolean);
          return (
            <article data-card data-series-id={s.id}>
              <a
                data-expand
                href={`#${s.id}`}
                aria-expanded="false"
                aria-controls={`detail-${s.id}`}
                class="group block"
              >
                <div class="aspect-[4/3] overflow-hidden rounded-sm bg-cream-200">
                  {cover && (
                    <img
                      src={`/paintings/${s.id}/${cover.file}`}
                      alt={s.works[0]?.title ?? s.title}
                      loading="lazy"
                      class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                    />
                  )}
                </div>
                <div class="mt-4 font-sans text-[11px] uppercase tracking-widest text-ink-500">
                  Room {s.number}
                </div>
                <div class="mt-1 font-serif text-2xl italic text-ink-800">{s.title}</div>
                <div class="mt-2 font-sans text-[12px] uppercase tracking-wider text-ink-500 transition-colors group-hover:text-ink-700">
                  View exhibition →
                </div>
              </a>

              <div id={`detail-${s.id}`} data-detail hidden>
                <a
                  data-collapse
                  href="/gallery"
                  class="font-sans text-[11px] uppercase tracking-widest text-ink-500 hover:text-ink-700"
                >
                  ← All exhibitions
                </a>

                <div class="mt-10 font-sans text-[11px] uppercase tracking-widest text-ink-500">
                  Room {s.number}
                </div>
                <h2 class="mt-3 font-serif text-5xl font-normal leading-[1.05] tracking-tight md:text-6xl">
                  {s.title}
                </h2>
                <p class="mt-6 max-w-2xl font-serif text-[18px] italic leading-relaxed text-ink-600">
                  {s.intro.body}
                </p>

                {paragraphs.length > 0 && (
                  <div class="mt-12 max-w-2xl border-t border-ink-800/10 pt-10">
                    <div class="mb-5 font-sans text-[11px] uppercase tracking-widest text-ink-500">
                      Artist statement
                    </div>
                    <div class="space-y-5 font-serif text-[17px] leading-relaxed text-ink-700">
                      {paragraphs.map((p) => <p>{p}</p>)}
                    </div>
                  </div>
                )}

                <div class="mt-14">
                  <a
                    href={`/gallery/${s.id}/room`}
                    class="rounded-sm bg-ink-800 px-7 py-3.5 font-sans text-[13px] uppercase tracking-wider text-cream-50 transition-colors hover:bg-ink-700"
                  >
                    Enter the gallery →
                  </a>
                </div>
              </div>
            </article>
          );
        })}
      </div>
    </section>

    <footer
      class="flex items-center justify-between border-t border-ink-800/10 px-6 py-8 font-sans text-[11px] uppercase tracking-wider text-ink-500 md:px-10"
    >
      <div>CILA · Carolina Amat · Estudio 2025</div>
      <div class="flex gap-6">
        <a href="#">Instagram</a>
        <a href="/contact">Contact</a>
      </div>
    </footer>
  </main>
</Base>

<style>
  /* Expanded mode: collapse the grid to a single article and swap each card's
     trigger for its detail block. Grid mode (the default) uses the Tailwind
     utilities on the markup. */
  [data-exhibitions][data-state='expanded'] [data-grid-header] { display: none; }
  [data-exhibitions][data-state='expanded'] [data-grid] {
    display: block;
    margin-top: 0;
  }
  [data-exhibitions][data-state='expanded'] [data-card]:not(.is-active) { display: none; }
  [data-exhibitions][data-state='expanded'] [data-card].is-active [data-expand] { display: none; }
  [data-exhibitions][data-state='expanded'] [data-card].is-active [data-detail] { display: block; }
</style>

<script>
  const root = document.querySelector<HTMLElement>('[data-exhibitions]');
  if (root) {
    const cards = Array.from(root.querySelectorAll<HTMLElement>('[data-card]'));
    const cardById = new Map(cards.map((c) => [c.dataset.seriesId!, c] as const));

    function apply(active: HTMLElement | null): void {
      const update = () => {
        for (const c of cards) {
          c.classList.toggle('is-active', c === active);
          c.querySelector('[data-expand]')?.setAttribute('aria-expanded', String(c === active));
        }
        root!.setAttribute('data-state', active ? 'expanded' : 'grid');
      };
      // Smooth crossfade where supported; a hard swap everywhere else is fine.
      const doc = document as Document & { startViewTransition?: (cb: () => void) => unknown };
      if (typeof doc.startViewTransition === 'function') doc.startViewTransition(update);
      else update();
    }

    function expandFromHash(): void {
      const id = window.location.hash.replace(/^#/, '');
      apply(id ? cardById.get(id) ?? null : null);
    }

    root.addEventListener('click', (e) => {
      const expand = (e.target as HTMLElement).closest<HTMLAnchorElement>('[data-expand]');
      if (expand) {
        const card = expand.closest<HTMLElement>('[data-card]');
        const id = card?.dataset.seriesId;
        if (!id) return;
        e.preventDefault();
        window.history.pushState({ expanded: id }, '', `#${id}`);
        apply(card!);
        // Land at the top of the article so the detail reads cleanly.
        window.scrollTo({ top: 0, behavior: 'auto' });
        return;
      }
      const collapse = (e.target as HTMLElement).closest<HTMLAnchorElement>('[data-collapse]');
      if (collapse) {
        e.preventDefault();
        // If we got into the expanded state via expand(), undo via back() so
        // we don't pile up history entries. Otherwise (direct hash URL), just
        // strip the hash in place.
        const state = window.history.state as { expanded?: string } | null;
        if (state?.expanded) {
          window.history.back();
        } else {
          window.history.replaceState(null, '', window.location.pathname);
          apply(null);
        }
      }
    });

    window.addEventListener('popstate', expandFromHash);
    expandFromHash();
  }
</script>
