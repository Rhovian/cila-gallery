---
interface Props {
  variant?: 'light' | 'dark';
  current?: 'gallery' | 'about' | 'cv' | 'contact';
}

const { variant = 'dark', current } = Astro.props;
const isLight = variant === 'light';

const links = [
  { href: '/gallery', label: 'Exhibitions', key: 'gallery' as const },
  { href: '/about', label: 'About', key: 'about' as const },
  { href: '/cv', label: 'CV', key: 'cv' as const },
  { href: '/contact', label: 'Contact', key: 'contact' as const },
];

const brandClass = isLight ? 'text-cream-50' : 'text-ink-800';
const linkRest = isLight ? 'text-cream-50/75 hover:text-cream-50' : 'text-ink-600 hover:text-ink-800';
const linkActive = isLight ? 'text-cream-50' : 'text-ink-800';
const iconClass = isLight ? 'text-cream-50' : 'text-ink-800';
const rowBorder = isLight ? '' : 'border-b border-ink-800/10';
---

<nav class={`flex items-center justify-between px-6 py-5 md:px-10 md:py-6 ${rowBorder}`}>
  <a href="/" class={`font-serif text-xl font-medium tracking-widest ${brandClass}`}>CILA</a>

  <div class={`hidden gap-8 font-sans text-[13px] tracking-wider md:flex ${linkRest}`}>
    {links.map((l) => (
      <a href={l.href} class={current === l.key ? linkActive : ''}>{l.label}</a>
    ))}
  </div>

  <button
    type="button"
    aria-label="Open menu"
    aria-controls="site-nav-panel"
    aria-expanded="false"
    data-nav-open
    class={`-mr-2 inline-flex h-10 w-10 items-center justify-center md:hidden ${iconClass}`}
  >
    <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
      <path stroke-linecap="round" d="M4 7h16M4 12h16M4 17h16" />
    </svg>
  </button>
</nav>

<div
  id="site-nav-panel"
  data-nav-panel
  hidden
  class="fixed inset-0 z-50 bg-cream-50 md:hidden"
>
  <div class="flex items-center justify-between px-6 py-5">
    <a href="/" class="font-serif text-xl font-medium tracking-widest text-ink-800">CILA</a>
    <button
      type="button"
      aria-label="Close menu"
      data-nav-close
      class="-mr-2 inline-flex h-10 w-10 items-center justify-center text-ink-800"
    >
      <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <path stroke-linecap="round" d="M6 6l12 12M6 18 18 6" />
      </svg>
    </button>
  </div>

  <div class="flex flex-col gap-7 px-6 pt-10">
    {links.map((l) => (
      <a
        href={l.href}
        class={`font-serif text-4xl tracking-tight ${current === l.key ? 'italic text-ink-800' : 'text-ink-700'}`}
      >
        {l.label}
      </a>
    ))}
  </div>
</div>

<script>
  const panel = document.querySelector<HTMLElement>('[data-nav-panel]');
  const openBtn = document.querySelector<HTMLButtonElement>('[data-nav-open]');
  const closeBtn = document.querySelector<HTMLButtonElement>('[data-nav-close]');

  function setOpen(open: boolean) {
    if (!panel || !openBtn) return;
    panel.hidden = !open;
    openBtn.setAttribute('aria-expanded', open ? 'true' : 'false');
    document.body.style.overflow = open ? 'hidden' : '';
  }

  openBtn?.addEventListener('click', () => setOpen(true));
  closeBtn?.addEventListener('click', () => setOpen(false));
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && panel && !panel.hidden) setOpen(false);
  });
</script>
